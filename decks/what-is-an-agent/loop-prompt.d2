direction: right

in: "In" {
  style.fill: "#fff4ed"
  style.stroke: "#ff914d"
  style.stroke-width: 2
  style.border-radius: 8
}

llm: "LLM Call" {
  style.fill: "#f0f4ff"
  style.stroke: "#1836b2"
  style.stroke-width: 2
  style.border-radius: 8
}

out: "Out" {
  style.fill: "#fff4ed"
  style.stroke: "#ff914d"
  style.stroke-width: 2
  style.border-radius: 8
}

in -> llm
llm -> out
