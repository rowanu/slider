direction: right

# ── Input ────────────────────────────────────────────────────────────────────

agent_code: "Agent Code\n(any framework)" {
  style.border-radius: 4
}

# ── Runtime ──────────────────────────────────────────────────────────────────

runtime: "Runtime\n(Firecracker MicroVM)" {
  style.stroke: "#FF9900"
  style.fill: "#FFF8F0"
  style.border-radius: 8

  agent: "Your Agent" {
    style.stroke: "#DD344C"
    style.fill: "#FFF5F5"
    style.border-radius: 4
  }
}

# ── LLM ──────────────────────────────────────────────────────────────────────

llm: "Bedrock / Any LLM" {
  shape: image
  icon: ../aws-icons/artificial-intelligence/amazon-bedrock.svg
}

# ── Protocols ────────────────────────────────────────────────────────────────

protocols: "Protocols" {
  style.stroke: "#3F8624"
  style.fill: "#F0FFF0"
  style.border-radius: 8

  mcp: "MCP Server"
  a2a: "A2A Protocol"
  ws: "WebSocket"
}

# ── Connections ──────────────────────────────────────────────────────────────

agent_code -> runtime.agent: "deploy"
runtime.agent <-> llm: "InvokeModel"
runtime.agent -> protocols: "expose"
