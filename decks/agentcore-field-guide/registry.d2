direction: right

# ── Teams ────────────────────────────────────────────────────────────────────

teams: "Teams" {
  shape: person
}

# ── Registry ─────────────────────────────────────────────────────────────────

registry: "Registry" {
  style.stroke: "#DD344C"
  style.fill: "#FFF5F5"
  style.border-radius: 8

  catalog: "Catalog" {
    style.stroke: "#FF9900"
    style.fill: "#FFF8F0"
    style.border-radius: 8

    agents: "Agents"
    tools: "Tools"
    mcp: "MCP Servers"
  }

  governance: "Governance" {
    style.stroke: "#3F8624"
    style.fill: "#F0FFF0"
    style.border-radius: 8

    metadata: "Version & lifecycle"
    approval: "Approval workflow"
  }
}

# ── Discovery source ────────────────────────────────────────────────────────

live_mcp: "Live MCP Servers" {
  shape: cloud
}

# ── Connections ──────────────────────────────────────────────────────────────

teams <-> registry: "discover"
live_mcp -> registry: "auto-register" {
  style.stroke-dash: 4
}
