direction: right

# ── Agent ────────────────────────────────────────────────────────────────────

agent: "Agent" {
  shape: image
  icon: ../aws-icons/artificial-intelligence/amazon-bedrock-agentcore.svg
}

# ── Evaluations ──────────────────────────────────────────────────────────────

evals: "Evaluations" {
  style.stroke: "#FF9900"
  style.fill: "#FFF8F0"
  style.border-radius: 8

  judge: "LLM-as-Judge" {
    shape: image
    icon: ../aws-icons/artificial-intelligence/amazon-bedrock.svg
  }

  builtin: "13+ built-in\nevaluators"
}

# ── Modes ────────────────────────────────────────────────────────────────────

on_demand: "On-Demand\n(CI/CD)" {
  style.border-radius: 4
}

online: "Online\n(live traffic)" {
  style.border-radius: 4
}

# ── Output ───────────────────────────────────────────────────────────────────

score: "Quality Scores" {
  style.stroke: "#3F8624"
  style.fill: "#F0FFF0"
  style.border-radius: 8
}

# ── Connections ──────────────────────────────────────────────────────────────

agent -> evals.judge: "agent output"
evals.judge -> evals.builtin: "apply"
on_demand -> evals: "ad hoc / CI"
online -> evals: "continuous" {
  style.stroke-dash: 4
}
evals -> score: "results"
