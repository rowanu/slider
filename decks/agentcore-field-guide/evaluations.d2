direction: right

# ── Agent ────────────────────────────────────────────────────────────────────

agent: "Agent" {
  shape: person
}

# ── Observability ────────────────────────────────────────────────────────────

obs: "Observability" {
  shape: image
  icon: ../aws-icons/management-tools/aws-distro-for-opentelemetry.svg
}

# ── Evaluations ──────────────────────────────────────────────────────────────

evals: "Evaluations" {
  style.stroke: "#FF9900"
  style.fill: "#FFF8F0"
  style.border-radius: 8

  builtin: "13+ built-in\nevaluators"
  custom: "Custom\n(LLM or Lambda)"
  on_demand: "On-Demand (CI/CD)"
  online: "Online (live traffic)"
}

# ── Output ───────────────────────────────────────────────────────────────────

score: "Quality Scores" {
  style.stroke: "#3F8624"
  style.fill: "#F0FFF0"
  style.border-radius: 8
}

# ── Connections ──────────────────────────────────────────────────────────────

agent -> obs: "traces" {
  style.stroke-dash: 4
}
obs -> evals: "read traces" {
  style.stroke-dash: 4
}
evals -> score: "results"
