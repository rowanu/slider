direction: right

# ── Agent ────────────────────────────────────────────────────────────────────

agent: "Agent" {
  shape: image
  icon: ../aws-icons/artificial-intelligence/amazon-bedrock-agentcore.svg
}

# ── Observability ────────────────────────────────────────────────────────────

obs: "Observability" {
  shape: image
  icon: ../aws-icons/management-tools/aws-distro-for-opentelemetry.svg
}

# ── Evaluations ──────────────────────────────────────────────────────────────

evals: "Evaluations" {
  style.stroke: "#FF9900"
  style.fill: "#FFF8F0"
  style.border-radius: 8

  builtin: "13+ built-in\nevaluators"
  custom: "Custom\n(LLM or Lambda)"
}

# ── Modes ────────────────────────────────────────────────────────────────────

on_demand: "On-Demand\n(CI/CD)" {
  style.border-radius: 4
}

online: "Online\n(live traffic)" {
  style.border-radius: 4
}

# ── Output ───────────────────────────────────────────────────────────────────

score: "Quality Scores" {
  style.stroke: "#3F8624"
  style.fill: "#F0FFF0"
  style.border-radius: 8
}

# ── Connections ──────────────────────────────────────────────────────────────

agent -> obs: "traces" {
  style.stroke-dash: 4
}
obs -> evals: "read traces"
on_demand -> evals: "ad hoc / CI"
online -> evals: "continuous" {
  style.stroke-dash: 4
}
evals -> score: "results"
