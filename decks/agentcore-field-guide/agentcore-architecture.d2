# AgentCore Architecture — How the services connect at runtime

direction: right

# ── External ──────────────────────────────────────────────────────────────────

user: "User / App" {
  shape: person
}

# ── Agent Compute ─────────────────────────────────────────────────────────────

compute: "Agent Compute" {
  style.stroke: "#FF9900"
  style.fill: "#FFF8F0"

  runtime: "Runtime" {
    style.border-radius: 8
  }

  code_interpreter: "Code Interpreter" {
    style.border-radius: 8
  }

  browser: "Browser" {
    style.border-radius: 8
  }

  runtime -> code_interpreter: "execute code"
  runtime -> browser: "browse web"
}

# ── Integration ───────────────────────────────────────────────────────────────

gateway: "Gateway" {
  style.border-radius: 8
}

memory: "Memory" {
  style.border-radius: 8
}

tools: "External Tools\n(Slack, Jira, APIs)" {
  shape: cloud
}

# ── Security ──────────────────────────────────────────────────────────────────

security: "Security & Governance" {
  style.stroke: "#DD344C"
  style.fill: "#FFF5F5"

  identity: "Identity" {
    style.border-radius: 8
  }

  policy: "Policy" {
    style.border-radius: 8
  }

  registry: "Registry" {
    style.border-radius: 8
  }
}

# ── Observability ─────────────────────────────────────────────────────────────

monitoring: "Observe & Evaluate" {
  style.stroke: "#3F8624"
  style.fill: "#F0FFF0"

  observability: "Observability" {
    style.border-radius: 8
  }

  evaluations: "Evaluations" {
    style.border-radius: 8
  }
}

# ── LLM ───────────────────────────────────────────────────────────────────────

bedrock: "Bedrock / Any LLM" {
  shape: image
  icon: ../aws-icons/artificial-intelligence/amazon-bedrock.svg
}

# ── Connections ───────────────────────────────────────────────────────────────

user -> security.identity: "authenticate"
user -> compute.runtime: "invoke"
compute.runtime -> bedrock: "InvokeModel"
compute.runtime -> gateway: "call tools"
compute.runtime <-> memory: "read/write context"
gateway -> tools: "MCP"
security.policy -> gateway: "intercept" {
  style.stroke-dash: 4
}
security.registry -> gateway: "discover" {
  style.stroke-dash: 4
}
monitoring.observability -> compute.runtime: "traces" {
  style.stroke-dash: 4
}
monitoring.evaluations -> compute.runtime: "evaluate" {
  style.stroke-dash: 4
}
