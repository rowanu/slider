direction: right

# ── Sources ──────────────────────────────────────────────────────────────────

sources: "Tool Sources" {
  style.stroke: "#FF9900"
  style.fill: "#FFF8F0"
  style.border-radius: 8

  lambda: "Lambda" {
    shape: image
    icon: ../aws-icons/compute/aws-lambda.svg
  }

  openapi: "OpenAPI Spec" {
    style.border-radius: 4
  }

  apis: "Existing APIs" {
    shape: cloud
  }
}

# ── Gateway ──────────────────────────────────────────────────────────────────

gw: "Gateway" {
  style.stroke: "#00A4A6"
  style.fill: "#E6F7F7"
  style.border-radius: 8
}

# ── Integrations ─────────────────────────────────────────────────────────────

integrations: "1-Click Integrations" {
  style.stroke: "#3F8624"
  style.fill: "#F0FFF0"
  style.border-radius: 8

  slack: "Slack"
  jira: "Jira"
  github: "GitHub"
}

# ── Consumers ────────────────────────────────────────────────────────────────

agent: "Agent" {
  shape: person
}

lattice: "VPC Lattice\n(private)" {
  shape: image
  icon: ../aws-icons/networking-content-delivery/amazon-vpc-lattice.svg
}

# ── Connections ──────────────────────────────────────────────────────────────

sources.lambda -> gw: "import"
sources.openapi -> gw: "import"
sources.apis -> gw: "import"
integrations -> gw: "built-in"
agent -> gw: "discover & call\n(MCP)"
gw -> lattice: "private access"
