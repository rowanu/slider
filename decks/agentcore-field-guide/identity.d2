direction: right

# ── User ─────────────────────────────────────────────────────────────────────

user: "User" {
  shape: person
}

# ── Identity ─────────────────────────────────────────────────────────────────

identity: "Identity" {
  shape: image
  icon: ../aws-icons/artificial-intelligence/amazon-bedrock-agentcore.svg
}

# ── Agent ────────────────────────────────────────────────────────────────────

agent_arn: "Agent\n(unique ARN)" {
  style.border-radius: 8
}

# ── Credential Vault ─────────────────────────────────────────────────────────

vault: "Credential Vault" {
  style.stroke: "#DD344C"
  style.fill: "#FFF5F5"
  style.border-radius: 8
}

# ── Downstream Tools ─────────────────────────────────────────────────────────

tools: "Tools & APIs" {
  shape: cloud
}

# ── Connections ──────────────────────────────────────────────────────────────

user -> identity: "3LO\ndelegate access"
identity -> agent_arn: "issue credentials"
agent_arn -> tools: "act as user"
identity -> agent_arn: "2LO\nclient credentials" {
  style.stroke-dash: 4
}
vault -> agent_arn: "3rd-party tokens" {
  style.stroke-dash: 4
}
