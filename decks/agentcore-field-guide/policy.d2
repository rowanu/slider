direction: right

# ── Agent ────────────────────────────────────────────────────────────────────

agent: "Agent" {
  shape: person
}

# ── Gateway ──────────────────────────────────────────────────────────────────

gw: "Gateway" {
  style.stroke: "#00A4A6"
  style.fill: "#E6F7F7"
  style.border-radius: 8
}

# ── Policy ───────────────────────────────────────────────────────────────────

policy: "Policy\n(Cedar)" {
  style.stroke: "#DD344C"
  style.fill: "#FFF5F5"
  style.border-radius: 8

  log: "LOG_ONLY\n(shadow)"
  enforce: "ENFORCE\n(block)"
}

# ── Tools ────────────────────────────────────────────────────────────────────

tools: "Tools" {
  shape: cloud
}

# ── Connections ──────────────────────────────────────────────────────────────

agent -> gw: "call tool"
gw <-> policy: "check policy" {
  style.stroke-dash: 4
  style.stroke: "#DD344C"
}
gw -> tools: "execute"
