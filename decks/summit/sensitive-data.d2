# Sensitive Data — Memory-aware IAM access

direction: right

agent: "Tax Assistant" {
  shape: image
  icon: ../aws-icons/artificial-intelligence/amazon-bedrock-agentcore.svg
}

iam: "IAM Role\n(least privilege)" {
  shape: image
  icon: ../aws-icons/security-identity/aws-identity-and-access-management.svg
}

memory: "AgentCore\nMemory" {
  shape: image
  icon: ../aws-icons/artificial-intelligence/amazon-bedrock-agentcore.svg
}

denied: "✗ Other Users'\nMemory — namespace\ncondition fails" {
  style.font-color: "#DD344C"
  style.stroke: "#DD344C"
  style.fill: "#FFF5F5"
  style.border-radius: 8
}

agent -> iam

iam -> memory: "RetrieveMemoryRecords\nnamespace: /actor/[userId]/..." {
  style.stroke: "#3F8624"
  style.stroke-width: 2
  style.font-color: "#3F8624"
  style.font-size: 13
}

iam -> denied: "✗ condition fails" {
  style.stroke: "#DD344C"
  style.stroke-dash: 4
  style.font-color: "#DD344C"
  style.font-size: 13
}
