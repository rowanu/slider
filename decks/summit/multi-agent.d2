# Tax Assistant — Decomposed so each sub-agent is missing a leg

direction: right

user: "Taxpayer" {
  shape: person
  style.stroke: "#232F3E"
  style.fill: "#232F3E"
}

agentcore: "Amazon Bedrock AgentCore" {
  style.stroke: "#232F3E"
  style.fill: "#FAFAFA"
  style.border-radius: 12
  style.font-size: 16
  style.bold: true

  orchestrator: "Orchestrator" {
    shape: image
    icon: ../aws-icons/artificial-intelligence/amazon-bedrock-agentcore.svg
  }

  parser: "Document Parser\n— Scoped Data" {
    shape: image
    icon: ../aws-icons/artificial-intelligence/amazon-bedrock.svg
    style.font-size: 13
  }

  advisor: "Personal Advisor\n— Read-Only" {
    shape: image
    icon: ../aws-icons/artificial-intelligence/amazon-bedrock.svg
    style.font-size: 13
  }

  submitter: "ATO Submitter\n— Curated Input" {
    shape: image
    icon: ../aws-icons/artificial-intelligence/amazon-bedrock.svg
    style.font-size: 13
  }

  orchestrator -> parser: "" { style.stroke: "#FF9900" }
  orchestrator -> advisor: "" { style.stroke: "#FF9900" }
  orchestrator -> submitter: "" { style.stroke: "#FF9900" }
}

uploads: "Receipts\nbucket" {
  shape: image
  icon: ../aws-icons/storage/amazon-simple-storage-service_bucket.svg
}

records: "Tax records" {
  shape: image
  icon: ../aws-icons/databases/amazon-dynamodb.svg
}

ato: "ATO API" {
  shape: image
  icon: ../aws-icons/cloud-financial-management/aws-cost-explorer.svg
}

user -> agentcore.orchestrator: "asks" {
  style.stroke: "#232F3E"
  style.font-size: 13
}

agentcore.parser -> uploads: "one doc" {
  style.stroke: "#3F8624"
  style.font-size: 13
}

agentcore.advisor -> records: "read" {
  style.stroke: "#3F8624"
  style.font-size: 13
}

agentcore.submitter -> ato: "structured\nsubmission" {
  style.stroke: "#3F8624"
  style.font-size: 13
}
