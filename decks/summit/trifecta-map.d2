# Three Patterns — Break a Leg

direction: right

# ── Pattern 1: Read-only ──────────────────────────────────────────────────

readonly: "Read-Only\nNo external actions" {
  style.stroke: "#232F3E"
  style.fill: "#F5F6F8"
  style.border-radius: 12
  style.font-size: 18
  style.bold: true

  sd1: "Sensitive Data" {
    style.stroke: "#00A4A6"
    style.fill: "#E6F7F7"
    style.border-radius: 6
    style.font-size: 14
  }
  uc1: "Untrusted Content" {
    style.stroke: "#FF9900"
    style.fill: "#FFF3E0"
    style.border-radius: 6
    style.font-size: 14
  }
  ea1: "✗ External Actions" {
    style.stroke: "#DD344C"
    style.fill: "#FFF5F5"
    style.font-color: "#DD344C"
    style.border-radius: 6
    style.font-size: 14
    style.bold: true
  }
}

# ── Pattern 2: Curated input ──────────────────────────────────────────────

curated: "Curated Input\nNo untrusted content" {
  style.stroke: "#232F3E"
  style.fill: "#F5F6F8"
  style.border-radius: 12
  style.font-size: 18
  style.bold: true

  sd2: "Sensitive Data" {
    style.stroke: "#00A4A6"
    style.fill: "#E6F7F7"
    style.border-radius: 6
    style.font-size: 14
  }
  uc2: "✗ Untrusted Content" {
    style.stroke: "#DD344C"
    style.fill: "#FFF5F5"
    style.font-color: "#DD344C"
    style.border-radius: 6
    style.font-size: 14
    style.bold: true
  }
  ea2: "External Actions" {
    style.stroke: "#232F3E"
    style.fill: "#E8EAF0"
    style.border-radius: 6
    style.font-size: 14
  }
}

# ── Pattern 3: Scoped data ────────────────────────────────────────────────

scoped: "Scoped Data\nCaller's slice only" {
  style.stroke: "#232F3E"
  style.fill: "#F5F6F8"
  style.border-radius: 12
  style.font-size: 18
  style.bold: true

  sd3: "✗ Sensitive Data" {
    style.stroke: "#DD344C"
    style.fill: "#FFF5F5"
    style.font-color: "#DD344C"
    style.border-radius: 6
    style.font-size: 14
    style.bold: true
  }
  uc3: "Untrusted Content" {
    style.stroke: "#FF9900"
    style.fill: "#FFF3E0"
    style.border-radius: 6
    style.font-size: 14
  }
  ea3: "External Actions" {
    style.stroke: "#232F3E"
    style.fill: "#E8EAF0"
    style.border-radius: 6
    style.font-size: 14
  }
}
