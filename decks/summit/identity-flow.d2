# Identity Propagation Flow
# Shows how user identity flows through the agent chain

direction: right

# ── Correct flow ──────────────────────────────────────────────────────────

sarah: "Employee\n\"Sarah\"" {
  shape: person
  style.stroke: "#232F3E"
  style.fill: "#232F3E"
}

sso: "SSO Login" {
  shape: image
  icon: ../aws-icons/security-identity/aws-iam-identity-center.svg
}

agent: "HR Agent" {
  shape: image
  icon: ../aws-icons/artificial-intelligence/amazon-bedrock-agentcore.svg
}

gateway: "AgentCore\nGateway" {
  shape: image
  icon: ../aws-icons/networking-content-delivery/amazon-api-gateway.svg
}

cedar: "Cedar\nPolicy" {
  shape: image
  icon: ../aws-icons/security-identity/amazon-verified-permissions.svg
}

payroll: "Payroll API" {
  shape: image
  icon: ../aws-icons/cloud-financial-management/aws-cost-explorer.svg
}

# ── Connections (identity flows through) ──────────────────────────────────

sarah -> sso: "authenticates" {
  style.stroke: "#FF9900"
  style.font-color: "#232F3E"
  style.font-size: 14
}

sso -> agent: "OAuth token\n(Sarah's identity)" {
  style.stroke: "#FF9900"
  style.font-color: "#232F3E"
  style.font-size: 14
}

agent -> gateway: "acts AS Sarah" {
  style.stroke: "#00A4A6"
  style.font-color: "#232F3E"
  style.font-size: 14
  style.bold: true
}

gateway -> cedar: "check permissions" {
  style.stroke: "#00A4A6"
  style.font-color: "#232F3E"
  style.font-size: 14
}

cedar -> payroll: "Sarah's record only" {
  style.stroke: "#3F8624"
  style.font-color: "#232F3E"
  style.font-size: 14
}

# ── Wrong way (crossed out) ──────────────────────────────────────────────

wrong: "✗ Agent uses service\naccount with full access" {
  style.stroke: "#DD344C"
  style.fill: "#FFF5F5"
  style.border-radius: 8
  style.font-color: "#DD344C"
  style.font-size: 16
  style.bold: true
}

agent -> wrong: "" {
  style.stroke: "#DD344C"
  style.stroke-dash: 4
}
