# Tax Assistant Architecture — AgentCore example
# Render: just diagram summit tax-assistant

direction: right

# ── Actor ────────────────────────────────────────────────────────────────────

taxpayer: "Taxpayer" {
  shape: person
  style.stroke: "#232F3E"
  style.fill: "#232F3E"
}

# ── Agent ────────────────────────────────────────────────────────────────────

tax_agent: "Tax Assistant" {
  shape: image
  icon: ../aws-icons/artificial-intelligence/amazon-bedrock-agentcore.svg
}

# ── Tools container ─────────────────────────────────────────────────────────

tools: "Tools" {
  grid-columns: 4
  style.stroke: "#232F3E"
  style.fill: "#FAFAFA"
  style.border-radius: 8

  records: "Tax Records\n& TFN" {
    shape: image
    icon: ../aws-icons/databases/amazon-dynamodb.svg
  }

  docs: "Receipts &\nStatements" {
    shape: image
    icon: ../aws-icons/storage/amazon-simple-storage-service_bucket-with-objects.svg
  }

  ato: "ATO Portal\n& BAS" {
    shape: image
    icon: ../aws-icons/cloud-financial-management/aws-cost-explorer.svg
  }

  bank: "Bank &\nSuper APIs" {
    shape: image
    icon: ../aws-icons/application-integration/amazon-appflow.svg
  }
}

# ── Connections ──────────────────────────────────────────────────────────────

taxpayer -> tax_agent: "natural language request" {
  style.stroke: "#FF9900"
  style.font-color: "#232F3E"
}

tax_agent -> tools: "tool calls" {
  style.stroke: "#00A4A6"
  style.font-color: "#232F3E"
}
